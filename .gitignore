# bv (beads viewer) local config and caches
.bv/

# Rust build directories (standard and colored variants)
/target/
/target-*/

# Test output logs (ephemeral).
# NOTE: these were committed BEFORE the ignore rules existed, so the rules were
# inert (gitignore never applies to already-tracked paths). Untrack them with
# `git rm -r --cached tests/logs tests/e2e/logs` and the rules take effect.
# Ignore the whole directories rather than an extension allowlist, so a new
# log suffix does not silently start getting committed again.
/tests/logs/
/tests/e2e/logs/

# IDE and editor
.idea/
.vscode/
*.swp
*~

# Web dashboard (Next.js)
/web/node_modules/
/web/dist/
/web/.next/

# Local scratch DBs
storage.sqlite3
storage.sqlite3-*

# Stray compiler output
a.out

# OS files
.DS_Store
Thumbs.db

# ACFS ephemeral patterns (auto-generated agent artifacts)
core
core.*
cline.mcp.json
codex.mcp.json
cursor.mcp.json
gemini.mcp.json
opencode.json
windsurf.mcp.json
*.mcp.json.*.bak
.opencode.json.*.bak
.windsurf.mcp.json.*.bak
.agent-mail-project-id
.agent-mail.yaml
*.sqlite3.bak
*.sqlite3.corrupt*
storage.sqlite3.corrupt-*
storage.sqlite3-shm.corrupt-*
storage.sqlite3-wal.corrupt-*
.beads/*.corrupt*
.beads/*.pre_repair_*
.beads/*.repair_candidate_*
.beads/*.bak-corrupt
.claude/

# beads local snapshot history. `br` rewrites these on every flush; they are a
# local undo log, not shared state (.beads/issues.jsonl is the tracked source of
# truth). Committed before an ignore rule existed — untrack with
# `git rm -r --cached .beads/.br_history`.
.beads/.br_history/

# Sibling path-dependency checkouts staged by the CI workflows. vc's Cargo.toml
# points at ../frankentui and ../frankensqlite; CI clones them here and rewrites
# the manifest (see .github/workflows/ci.yml). Never commit either the clones or
# a rewritten Cargo.toml.
/.ci/

# Nested crate build artifacts (e.g., crates/vc_tui/target/)
crates/*/target/
